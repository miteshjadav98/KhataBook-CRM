generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Shop {
  id                    String   @id @default(uuid())
  shopCode              String   @unique @default(cuid()) // Alphanumeric code for login
  name                  String
  interestRate          Float    @default(0) // Example: 2 for 2%
  defaultCreditDuration Int      @default(30) // in days
  locale                String   @default("hi") // Language preference (hi, gu, en)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  users        User[]
  customers    Customer[]
  products     Product[]
  transactions Transaction[]
}

enum Role {
  ADMIN
  STAFF
}

model User {
  id           String   @id @default(uuid())
  shopId       String
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model Customer {
  id                  String    @id @default(uuid())
  shopId              String
  name                String
  phone               String?
  email               String?
  passwordHash        String
  totalBalance        Float     @default(0) // Positive = customer owes shop (Udhar), Negative = shop owes customer (Advance)
  isTemporaryPassword Boolean   @default(true)
  passwordUpdatedAt   DateTime?
  isDeleted           Boolean   @default(false)
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([shopId, phone]) // Phone is unique within a shop
  @@unique([shopId, email]) // Email is unique within a shop
}

model Product {
  id        String    @id @default(uuid())
  shopId    String
  name      String
  price     Float
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

enum TxType {
  UDHAR // Customer took goods on credit (increases what they owe)
  JAMA  // Customer made a payment (reduces what they owe)
}

enum TxStatus {
  PAID
  DUE
  OVERDUE
}

model Transaction {
  id              String    @id @default(uuid())
  shopId          String
  customerId      String
  productId       String?
  type            TxType
  totalAmount     Float     // Full bill amount (for UDHAR) or payment amount (for JAMA)
  paidAmount      Float     @default(0)
  remainingAmount Float     @default(0)
  discountAmount  Float     @default(0)
  interestRate    Float     @default(0) // Monthly interest rate for this transaction
  interestApplied Float     @default(0) // Accumulated interest so far
  status          TxStatus  @default(DUE)
  description     String?   // Optional note like "Toor Dal 2kg"
  dueDate         DateTime?
  transactionDate DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([shopId, customerId, transactionDate(sort: Desc)])
  @@index([shopId, status])
}
